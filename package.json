{
  "name": "@kingslanding/cli",
  "version": "0.2.0",
  "description": "Deploy static sites to King's Landing from any terminal or CI/CD pipeline",
  "type": "module",
  "bin": {
    "kl": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/ tests/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run lint && npm run typecheck && npm run test",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/boxshopio/kingslanding-cli.git"
  },
  "keywords": [
    "deploy",
    "hosting",
    "static-site",
    "cli"
  ],
  "license": "PROPRIETARY",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^13.0.0",
    "glob": "^11.0.0",
    "mime-types": "^3.0.2",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "@vitest/coverage-v8": "^3.0.0",
    "vitest": "^3.0.0"
  }
}
